@inherits LayoutComponentBase
@using System.Globalization
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@L["AppName"] <span class="text-muted">· @L["AppTagline"]</span></span>
            <div class="d-flex align-items-center gap-3">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-muted small" title="@L["Demo_Persona"]">
                            <span class="bi bi-person-circle" aria-hidden="true"></span>
                            @L["Persona_SignedInAs"]: <span class="fw-medium">@PersonaName(context)</span>
                        </span>
                        <a href="demo/logout" class="btn btn-sm btn-outline-secondary">@L["Persona_SignOut"]</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="login" class="btn btn-sm btn-outline-primary">@L["Login_SignInAs"]</a>
                    </NotAuthorized>
                </AuthorizeView>
                <a href="@CultureSwitchUrl" class="btn btn-sm btn-outline-secondary" rel="nofollow">
                    <span class="bi bi-translate" aria-hidden="true"></span> @L["Language_Switch"]
                </a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["Error_Unhandled"]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string PersonaName(AuthenticationState state)
    {
        var user = state.User;
        return Ui.Lang == "ar"
            ? user.FindFirst("name_ar")?.Value ?? user.Identity?.Name ?? string.Empty
            : user.Identity?.Name ?? string.Empty;
    }

    private string CultureSwitchUrl
    {
        get
        {
            var target = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" ? "en" : "ar";
            var relative = "/" + Nav.ToBaseRelativePath(Nav.Uri);
            return $"set-culture?culture={target}&redirectUri={Uri.EscapeDataString(relative)}";
        }
    }
}
