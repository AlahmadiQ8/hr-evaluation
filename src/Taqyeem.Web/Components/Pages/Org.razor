@page "/org"
@attribute [Authorize]
@inject TaqyeemApiClient Api
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Org_Title"]</PageTitle>

<h1>@L["Org_Title"]</h1>

@if (_sectors is null)
{
    <p role="status">@L["Common_Loading"]</p>
}
else
{
    foreach (OrgSectorDto sector in _sectors)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-header fw-semibold">@sector.Name.For(Ui.Lang)</div>
            <ul class="list-group list-group-flush">
                @foreach (OrgDepartmentDto dept in sector.Departments)
                {
                    <li class="list-group-item">
                        <div class="fw-medium">@dept.Name.For(Ui.Lang)</div>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @foreach (OrgDivisionDto div in dept.Divisions)
                            {
                                <span class="badge text-bg-light border">
                                    @div.Name.For(Ui.Lang)
                                    <span class="text-muted">· @div.EmployeeCount @L["Org_Employees"]</span>
                                </span>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
}

@code {
    private List<OrgSectorDto>? _sectors;

    protected override async Task OnInitializedAsync() => _sectors = await Api.GetOrgTreeAsync();
}
